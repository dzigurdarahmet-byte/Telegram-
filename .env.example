# ═══════════════════════════════════════════════════════════
#  iiko + Claude Telegram Bot — Конфигурация
#  Скопируйте этот файл: cp .env.example .env
#  Затем заполните значения
# ═══════════════════════════════════════════════════════════

# ─── 1. Telegram Bot Token ─────────────────────────────────
# Получить: откройте @BotFather в Telegram → /newbot
TELEGRAM_BOT_TOKEN=ваш_токен_от_botfather

# ─── 2. iiko API Login ─────────────────────────────────────
# Получить: iikoWeb → Настройки → API → Создать API-логин
IIKO_API_LOGIN=ваш_api_логин_iiko

# ─── 3a. Anthropic API Key (Claude — резервный AI) ────────
# Получить: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-ваш_ключ

# ─── 3b. OpenAI API Key (основной AI) ─────────────────────
# Получить: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-ваш_ключ_openai
# Модель: gpt-4o, gpt-4o-mini, o1, o3-mini
OPENAI_MODEL=gpt-4o

# ─── 4a. Ограничение доступа (опционально) ─────────────────
# Telegram user ID через запятую. Если пусто — доступ у всех.
# Узнать свой ID: напишите @userinfobot в Telegram
ALLOWED_USERS=

# ─── 4b. Одобренные пользователи ──────────────────────────
# Пользователи с доступом к боту (без админских прав)
APPROVED_USERS=

# ─── 5a. Автоотчёты (опционально) ──────────────────────────
# Chat ID для утренних/вечерних отчётов
ADMIN_CHAT_ID=

# ─── 5b. iiko Server (локальный, опционально) ──────────────
# Если есть локальный сервер iiko — данные зала, OLAP-отчёты
IIKO_SERVER_URL=https://localhost:443
IIKO_SERVER_LOGIN=
IIKO_SERVER_PASSWORD=

# ─── 6. Производительность поваров (для /cooks) ──────────
# Коды ролей поваров в iiko (через запятую). /debugcooks покажет все роли.
COOK_ROLE_CODES=POV
# Количество поваров в смене (если 0 — считает всех с ролью POV из iiko)
COOKS_PER_SHIFT=0
# Фолбэк зарплаты (если нет Google Sheets)
COOK_SALARY_PER_SHIFT=3000

# ─── 7. Яндекс Еда Вендор (доставка) ────────────────────
# Получить: vendor.yandex.ru → Настройки → API
YANDEX_EDA_CLIENT_ID=
YANDEX_EDA_CLIENT_SECRET=

# ─── 8. Google Sheets (зарплаты поваров) ─────────────────
# ID таблицы из URL: https://docs.google.com/spreadsheets/d/{ID}/edit
# Средняя дневная зарплата считается автоматически из данных таблицы
GOOGLE_SHEET_ID=

# ─── 9. Исключённые из отчётов (не обслуживают зал) ──────
EXCLUDED_STAFF=Стаховский Сергей,denvic

# ─── 10. KPI официантов ──────────────────────────────────
WAITER_MONTHLY_TARGET=1000000
TRAINEE_MONTHLY_TARGET=300000

# ─── 11. Мониторинг стоп-листа ──────────────────────────
# Автоматическая проверка каждые N секунд, уведомление при изменениях
STOP_MONITOR_ENABLED=true
STOP_MONITOR_INTERVAL=600
# Куда слать уведомления (по умолчанию = ADMIN_CHAT_ID)
STOP_MONITOR_CHAT_ID=

# ─── 12. Алерты аномалий ────────────────────────────────
ANOMALY_ALERTS_ENABLED=true
ANOMALY_CHECK_INTERVAL=1800
# Порог: выручка < 40% от нормы = аномалия
ANOMALY_REVENUE_LOW_PCT=0.4
ANOMALY_CHAT_ID=
# Рабочие часы ресторана (для алертов)
RESTAURANT_OPEN_HOUR=12
RESTAURANT_CLOSE_HOUR=22
